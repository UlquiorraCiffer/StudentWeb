---
const { currentPath = '/' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/courses', label: 'Courses' },
  { href: '/faculty', label: 'Faculty' },
  { href: '/facilities', label: 'Facilities' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50">
  <nav class="max-w-[var(--page-max-width)] mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-lg md:text-xl font-medium text-[var(--color-pure-white)] flex items-center gap-2 shrink-0" style="font-family: var(--font-aeonikfono);">
      Eklavya
      <span class="nav-ai-badge hidden sm:inline-flex">&#9889; AI-Powered</span>
    </a>

    <div class="hidden md:flex glass-pill items-center gap-5 px-6 py-2.5 rounded-full text-sm" style="font-family: var(--font-aeonik);">
      {navLinks.map(p => {
        const isActive = (p.href === '/' ? currentPath === '/' : currentPath.startsWith(p.href));
        return (
          <a
            href={p.href}
            class={`transition-colors whitespace-nowrap ${isActive ? 'text-[var(--color-neon-pulse)] font-medium' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
          >
            {p.label}
          </a>
        );
      })}
    </div>

    <a href="/contact" class="hidden md:inline-block">
      <button class="btn-neon px-5 py-2.5 text-sm min-h-[44px]">Enquire Now</button>
    </a>
  </nav>

  <div class="md:hidden border-t border-[rgba(208,211,211,0.12)]">
    <div class="flex max-w-[var(--page-max-width)] mx-auto">
      <a
        href="/"
        class={`flex-1 text-center py-2 text-[12px] font-medium transition-colors min-h-[44px] flex items-center justify-center ${currentPath === '/' ? 'text-[var(--color-neon-pulse)]' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
        style="font-family: var(--font-aeonik);"
      >Home</a>
      <a
        href="/courses"
        class={`flex-1 text-center py-2 text-[12px] font-medium transition-colors min-h-[44px] flex items-center justify-center ${currentPath.startsWith('/courses') ? 'text-[var(--color-neon-pulse)]' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
        style="font-family: var(--font-aeonik);"
      >Courses</a>
      <a
        href="/faculty"
        class={`flex-1 text-center py-2 text-[12px] font-medium transition-colors min-h-[44px] flex items-center justify-center ${currentPath.startsWith('/faculty') ? 'text-[var(--color-neon-pulse)]' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
        style="font-family: var(--font-aeonik);"
      >Faculty</a>
      <a
        href="/contact"
        class={`flex-1 text-center py-2 text-[12px] font-medium transition-colors min-h-[44px] flex items-center justify-center ${currentPath.startsWith('/contact') ? 'text-[var(--color-neon-pulse)]' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
        style="font-family: var(--font-aeonik);"
      >Contact</a>
    </div>
  </div>
</header>
