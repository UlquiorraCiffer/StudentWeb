---
const { currentPath = '/' } = Astro.props;

const pages = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/courses', label: 'Courses' },
  { href: '/faculty', label: 'Faculty' },
  { href: '/facilities', label: 'Facilities' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-[var(--surface-obsidian-canvas)] border-b border-[var(--color-fog-border)]">
  <nav class="max-w-[var(--page-max-width)] mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-xl font-medium text-[var(--color-pure-white)] flex items-center gap-2" style="font-family: var(--font-aeonikfono);">
      Eklavya
      <span class="nav-ai-badge hidden sm:inline-flex">&#9889; AI-Powered</span>
    </a>

    <div class="hidden md:flex gap-8 text-sm" style="font-family: var(--font-aeonik);">
      {pages.map(p => {
        const isActive = (p.href === '/' ? currentPath === '/' : currentPath.startsWith(p.href));
        return (
          <a
            href={p.href}
            class={`transition-colors ${isActive ? 'text-[var(--color-neon-pulse)] font-medium' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
          >
            {p.label}
          </a>
        );
      })}
    </div>

    <a href="/contact" class="hidden md:inline-block">
      <button class="bg-[var(--color-neon-pulse)] text-[var(--color-obsidian-shell)] px-6 py-2.5 rounded-full text-sm font-medium transition-opacity hover:opacity-85 min-h-[44px]" style="font-family: var(--font-aeonik); font-weight: 500;">
        Enquire Now
      </button>
    </a>
  </nav>

  <!-- Mobile tab links -->
  <div class="md:hidden border-t border-[var(--color-fog-border)]">
    <div class="flex max-w-[var(--page-max-width)] mx-auto">
      <a
        href="/"
        class={`flex-1 text-center py-2 text-[12px] font-medium transition-colors ${currentPath === '/' ? 'text-[var(--color-neon-pulse)]' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
        style="font-family: var(--font-aeonik);"
      >Home</a>
      <a
        href="/courses"
        class={`flex-1 text-center py-2 text-[12px] font-medium transition-colors ${currentPath.startsWith('/courses') ? 'text-[var(--color-neon-pulse)]' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
        style="font-family: var(--font-aeonik);"
      >Courses</a>
      <a
        href="/faculty"
        class={`flex-1 text-center py-2 text-[12px] font-medium transition-colors ${currentPath.startsWith('/faculty') ? 'text-[var(--color-neon-pulse)]' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
        style="font-family: var(--font-aeonik);"
      >Faculty</a>
      <a
        href="/contact"
        class={`flex-1 text-center py-2 text-[12px] font-medium transition-colors ${currentPath.startsWith('/contact') ? 'text-[var(--color-neon-pulse)]' : 'text-[var(--color-slate-text)] hover:text-[var(--color-pure-white)]'}`}
        style="font-family: var(--font-aeonik);"
      >Contact</a>
    </div>
  </div>
</header>
