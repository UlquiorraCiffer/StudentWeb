---
const stats = [
  { number: '9,000+', label: 'Students Taught', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z'/></svg>", growth: '+12%' },
  { number: '18,000+', label: 'Parents Trust Us', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z'/></svg>", growth: '+8%' },
  { number: '12+', label: 'Dedicated Faculty', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z'/></svg>", growth: '+2' },
  { number: '11+', label: 'Years of Legacy', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'/></svg>", growth: 'Since 2015' },
];
---

<section>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-5">
    {stats.map(s => (
      <div class="stat-card flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <div class="w-9 h-9 rounded-full bg-[rgba(61,220,145,0.1)] flex items-center justify-center text-[var(--color-neon-pulse)]" set:html={s.icon}>
          </div>
          <span class="text-[11px] font-medium text-[var(--color-neon-pulse)] flex items-center gap-0.5" style="font-family: var(--font-aeonik);">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
            {s.growth}
          </span>
        </div>
        <div class="text-[28px] md:text-[32px] font-medium leading-none text-[var(--color-neon-pulse)] mb-1.5" style="font-family: var(--font-aeonikfono); letter-spacing: -0.02em;">
          {s.number}
        </div>
        <div class="text-xs text-[var(--color-slate-text)]" style="font-family: var(--font-aeonik);">
          {s.label}
        </div>
      </div>
    ))}
  </div>
</section>
