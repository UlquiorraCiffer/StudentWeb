---
const steps = [
  { num: '01', title: 'Admission Enquiry', desc: 'Reach out via phone, in-person, or our enquiry form. We guide you through the process step by step.' },
  { num: '02', title: 'Choose Your Subjects', desc: 'Select from our wide range of subjects across Std 1-12 (Commerce). Gujarati & English mediums available.' },
  { num: '03', title: 'Excel in Studies', desc: 'Join regular classes, access study materials, and benefit from our focused academic approach.' },
];
---

<section>
  <h2 class="text-[var(--text-heading)] font-medium leading-[var(--leading-heading)] mb-10 md:mb-12" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
    How to Get Started
  </h2>
  <div class="bg-[var(--surface-deep-card)] rounded-[var(--radius-cards)] neon-border p-8 md:p-12">
    <div class="timeline-line space-y-10 md:space-y-12 pl-12 md:pl-14">
      {steps.map(s => (
        <div class="relative">
          <div class="absolute -left-12 md:-left-14 top-0 w-10 h-10 md:w-11 md:h-11 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center text-[var(--color-obsidian-shell)] font-bold text-sm md:text-base z-10 border-2 border-[var(--surface-deep-card)]" style="font-family: var(--font-aeonikfono);">
            {s.num}
          </div>
          <div>
            <h3 class="text-[var(--text-heading-sm)] font-medium mb-1.5" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
              {s.title}
            </h3>
            <p class="text-[var(--text-body)] text-[var(--color-slate-text)] leading-[var(--leading-body)] max-w-2xl" style="font-family: var(--font-aeonik);">
              {s.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
