---
const { icon, title, description, large } = Astro.props;
---

<div class="glass-card flex flex-col p-5 md:p-6 lg:p-8">
  <div class="w-11 h-11 md:w-12 md:h-12 bg-[var(--color-mint-whisper)] rounded-full flex items-center justify-center mb-4 shrink-0 border border-[rgba(61,220,145,0.3)]">
    <span class="text-[var(--color-obsidian-shell)]" set:html={icon}></span>
  </div>
  <h3 class="text-[15px] md:text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
    {title}
  </h3>
  <p class="text-[13px] md:text-[var(--text-body)] text-[var(--color-slate-text)] leading-[var(--leading-body)] grow" style="font-family: var(--font-aeonik);">
    {description}
  </p>
</div>
