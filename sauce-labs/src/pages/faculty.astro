---
import Layout from '../layouts/Layout.astro';

const std10Faculty = [
  { name: 'Hardik Sir', role: 'Std 10 & 12 English Faculty', subjects: 'English', initials: 'H' },
  { name: 'Ankit Sir', role: 'Std 10 Social Science Faculty', subjects: 'Social Science', initials: 'A' },
  { name: 'Devendra Sir', role: 'Std 10 Science Faculty', subjects: 'Science', initials: 'D' },
  { name: 'Sagar Sir', role: 'Std 10 Maths Faculty', subjects: 'Mathematics', initials: 'S' },
  { name: 'Suresh Sir', role: 'Std 10 & 12 Gujarati Faculty', subjects: 'Gujarati', initials: 'SU' },
  { name: 'Helvin Sir', role: 'Std 10 Sanskrit Faculty', subjects: 'Sanskrit', initials: 'HE' },
];

const std12Faculty = [
  { name: 'Arthik Sir', role: 'Std 12 Commerce Faculty', subjects: 'Accounts', initials: 'AR' },
  { name: 'Yogesh Sir', role: 'Std 12 Commerce Faculty', subjects: 'Statistics', initials: 'Y' },
  { name: 'Deepak Sir', role: 'Std 12 Commerce Faculty', subjects: 'Economics', initials: 'DE' },
  { name: 'Vijay Sir', role: 'Std 12 Commerce Faculty', subjects: 'B.A.', initials: 'V' },
];
---

<Layout title="Faculty | Eklavya Tuition Classes" description="Meet our dedicated faculty at Eklavya Tuition Classes — experienced teachers for Std 10 and Std 12 Commerce.">
  <div class="space-y-14 md:space-y-20">

    <section>
      <h1 class="font-medium leading-[var(--leading-display)] mb-6" style="font-family: var(--font-aeonikfono); font-size: var(--text-display); color: var(--color-pure-white);">
        Our Faculty
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-slate-text)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-aeonik);">
        Meet the dedicated educators behind Eklavya's success. Led by Director <strong class="text-[var(--color-pure-white)]">Yogeshbhai Katariya (M.Com, B.Ed)</strong> — 11 years of experience.
      </p>
    </section>

    <section>
      <h2 class="text-[var(--text-heading)] font-medium leading-[var(--leading-heading)] mb-8" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Std 10 Teachers
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-5">
        {std10Faculty.map(f => (
          <div class="glass-card flex flex-col items-center text-center p-5 md:p-7">
            <div class="w-14 h-14 md:w-16 md:h-16 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center mb-4 border-2 border-[rgba(61,220,145,0.3)]">
              <span class="text-[var(--color-obsidian-shell)] text-lg md:text-xl font-bold" style="font-family: var(--font-aeonikfono);">{f.initials}</span>
            </div>
            <h3 class="text-[14px] md:text-[var(--text-heading-sm)] font-medium mb-1" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">{f.name}</h3>
            <p class="text-[12px] md:text-sm text-[var(--color-neon-pulse)] mb-1" style="font-family: var(--font-aeonik);">{f.role}</p>
            <p class="text-[11px] md:text-xs text-[var(--color-slate-text)]" style="font-family: var(--font-aeonik);">{f.subjects}</p>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-[var(--text-heading)] font-medium leading-[var(--leading-heading)] mb-8" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Std 12 Commerce Teachers
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-5">
        {std12Faculty.map(f => (
          <div class="glass-card flex flex-col items-center text-center p-5 md:p-7">
            <div class="w-14 h-14 md:w-16 md:h-16 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center mb-4 border-2 border-[rgba(61,220,145,0.3)]">
              <span class="text-[var(--color-obsidian-shell)] text-lg md:text-xl font-bold" style="font-family: var(--font-aeonikfono);">{f.initials}</span>
            </div>
            <h3 class="text-[14px] md:text-[var(--text-heading-sm)] font-medium mb-1" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">{f.name}</h3>
            <p class="text-[12px] md:text-sm text-[var(--color-neon-pulse)] mb-1" style="font-family: var(--font-aeonik);">{f.role}</p>
            <p class="text-[11px] md:text-xs text-[var(--color-slate-text)]" style="font-family: var(--font-aeonik);">{f.subjects}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Director -->
    <section class="glass-card p-10 md:p-14 text-center">
      <div class="w-20 h-20 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center mx-auto mb-5 border-2 border-[rgba(61,220,145,0.3)]">
        <span class="text-[var(--color-obsidian-shell)] text-2xl font-bold" style="font-family: var(--font-aeonikfono);">YK</span>
      </div>
      <h2 class="text-[var(--text-heading-sm)] font-medium mb-1" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Yogeshbhai Katariya
      </h2>
      <p class="text-sm text-[var(--color-neon-pulse)] font-medium mb-4" style="font-family: var(--font-aeonik);">M.Com, B.Ed — 11 Years Experience</p>
      <p class="text-[var(--text-body)] text-[var(--color-slate-text)] max-w-xl mx-auto leading-relaxed" style="font-family: var(--font-aeonik);">
        "Eklavya — Where trust, education and future are guaranteed!"
      </p>
    </section>

  </div>
</Layout>
