const std12Subjects = [
  { name: 'Accounts', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'/></svg>", teacher: 'Arthik Sir' },
  { name: 'Statistics', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'/></svg>", teacher: 'Yogesh Sir' },
  { name: 'Economics', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M3 21h18M3 10h18M3 7l9-4 9 4M4 10v11m16-11v11M8 14v.5m8-.5v.5M8 18v.5m8-.5v.5'/></svg>", teacher: 'Deepak Sir' },
  { name: 'B.A.', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'/></svg>", teacher: 'Vijay Sir' },
  { name: 'English', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'/></svg>", teacher: 'Hardik Sir' },
  { name: 'Gujarati', icon: "<svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z'/></svg>", teacher: 'Suresh Sir' },
];

const feeStructure = [
  { standard: '1 to 3', fee: '₹9,000' },
  { standard: '4 & 5', fee: '₹9,500' },
  { standard: '6', fee: '₹10,500' },
  { standard: '7', fee: '₹11,500' },
  { standard: '8', fee: '₹12,500' },
  { standard: '9', fee: '₹14,000' },
  { standard: '10', fee: '₹19,000' },
  { standard: '11', fee: '₹18,000' },
  { standard: '12', fee: '₹19,500' },
];
---

<Layout title="Courses | Eklavya Tuition Classes" description="Std 1 to 12 Commerce coaching in Surat. Gujarati & English medium. Fee structure, subjects, and special courses at Eklavya Tuition Classes.">
  <div class="space-y-14 md:space-y-20">

    <section>
      <h1 class="font-medium leading-[var(--leading-display)] mb-6" style="font-family: var(--font-aeonikfono); font-size: var(--text-display); color: var(--color-pure-white);">
        Courses
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-slate-text)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-aeonik);">
        Comprehensive academic coaching for Class 1 to Class 12 (Commerce stream) in Gujarati and English mediums at Utran, Surat.
      </p>
    </section>

    <!-- Medium badges -->
    <section>
      <h2 class="text-[var(--text-heading)] font-medium leading-[var(--leading-heading)] mb-6" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Medium of Instruction
      </h2>
      <div class="flex flex-wrap gap-3">
        <span class="bg-[var(--color-neon-pulse)] text-[var(--color-obsidian-shell)] px-6 py-3 rounded-full text-sm font-medium" style="font-family: var(--font-aeonik); font-weight: 600;">
          Gujarati Medium
        </span>
        <span class="neon-border text-[var(--color-neon-pulse)] px-6 py-3 rounded-full text-sm font-medium" style="font-family: var(--font-aeonik); font-weight: 600;">
          English Medium
        </span>
      </div>
    </section>

    <!-- Std 10 Subjects -->
    <section>
      <h2 class="text-[var(--text-heading)] font-medium leading-[var(--leading-heading)] mb-8" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Std 10 Subjects
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-5">
        {std10Subjects.map(s => (
          <div class="glass-card flex flex-col p-4 md:p-6">
            <div class="w-10 h-10 md:w-12 md:h-12 bg-[rgba(61,220,145,0.1)] rounded-full flex items-center justify-center mb-3 md:mb-4 shrink-0">
              <span class="text-[var(--color-neon-pulse)]" set:html={s.icon}></span>
            </div>
            <h3 class="text-[14px] md:text-[var(--text-heading-sm)] font-medium mb-1" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">{s.name}</h3>
            <p class="text-xs md:text-sm text-[var(--color-neon-pulse)] grow" style="font-family: var(--font-aeonik);">{s.teacher}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Std 12 Commerce Subjects -->
    <section>
      <h2 class="text-[var(--text-heading)] font-medium leading-[var(--leading-heading)] mb-8" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Std 12 Commerce Subjects
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-5">
        {std12Subjects.map(s => (
          <div class="glass-card flex flex-col p-4 md:p-6">
            <div class="w-10 h-10 md:w-12 md:h-12 bg-[rgba(61,220,145,0.1)] rounded-full flex items-center justify-center mb-3 md:mb-4 shrink-0">
              <span class="text-[var(--color-neon-pulse)]" set:html={s.icon}></span>
            </div>
            <h3 class="text-[14px] md:text-[var(--text-heading-sm)] font-medium mb-1" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">{s.name}</h3>
            <p class="text-xs md:text-sm text-[var(--color-neon-pulse)] grow" style="font-family: var(--font-aeonik);">{s.teacher}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Fee Structure -->
    <section class="bg-[var(--surface-deep-card)] rounded-[var(--radius-cards)] neon-border p-6 md:p-12">
      <h2 class="text-[var(--text-heading)] font-medium leading-[var(--leading-heading)] mb-8" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Fee Structure (Annual)
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-[rgba(61,220,145,0.2)]">
              <th class="pb-4 text-sm font-medium text-[var(--color-neon-pulse)] uppercase tracking-wider" style="font-family: var(--font-aeonik);">Standard</th>
              <th class="pb-4 text-sm font-medium text-[var(--color-neon-pulse)] uppercase tracking-wider" style="font-family: var(--font-aeonik);">Annual Fee</th>
            </tr>
          </thead>
          <tbody>
            {feeStructure.map(f => (
              <tr class="border-b border-[rgba(61,220,145,0.1)] last:border-0 hover:bg-[rgba(61,220,145,0.03)] transition-colors">
                <td class="py-4 text-[var(--color-pure-white)]" style="font-family: var(--font-aeonik); font-size: var(--text-body);">{f.standard}</td>
                <td class="py-4 text-[var(--color-neon-pulse)] font-semibold" style="font-family: var(--font-aeonikfono); font-size: var(--text-body);">{f.fee}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Special Courses -->
    <section>
      <h2 class="text-[var(--text-heading)] font-medium leading-[var(--leading-heading)] mb-8" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Special Courses
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-5">
        <div class="glass-card flex flex-col p-5 md:p-6 lg:p-8">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-[rgba(61,220,145,0.1)] rounded-full flex items-center justify-center mb-3 md:mb-4 text-[var(--color-neon-pulse)] text-lg md:text-xl font-bold" style="font-family: var(--font-aeonikfono);">+</div>
          <h3 class="text-[14px] md:text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">Basic Maths</h3>
          <p class="text-xs md:text-sm text-[var(--color-neon-pulse)] mb-2" style="font-family: var(--font-aeonik);">Std 6 to 10 | ₹800/month</p>
          <p class="text-[12px] md:text-[var(--text-body)] text-[var(--color-slate-text)] leading-[var(--leading-body)] grow" style="font-family: var(--font-aeonik);">Strengthen your mathematical foundation with focused coaching and practice.</p>
        </div>
        <div class="glass-card flex flex-col p-5 md:p-6 lg:p-8">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-[rgba(61,220,145,0.1)] rounded-full flex items-center justify-center mb-3 md:mb-4 text-[var(--color-neon-pulse)] text-lg md:text-xl font-bold" style="font-family: var(--font-aeonikfono);">A</div>
          <h3 class="text-[14px] md:text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">Basic English</h3>
          <p class="text-xs md:text-sm text-[var(--color-neon-pulse)] mb-2" style="font-family: var(--font-aeonik);">Std 6 to 10 | ₹1,000/month</p>
          <p class="text-[12px] md:text-[var(--text-body)] text-[var(--color-slate-text)] leading-[var(--leading-body)] grow" style="font-family: var(--font-aeonik);">Improve your English grammar, vocabulary, and communication skills.</p>
        </div>
        <div class="glass-card flex flex-col p-5 md:p-6 lg:p-8">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-[rgba(61,220,145,0.1)] rounded-full flex items-center justify-center mb-3 md:mb-4 text-[var(--color-neon-pulse)] text-lg md:text-xl font-bold" style="font-family: var(--font-aeonikfono);">&#9889;</div>
          <h3 class="text-[14px] md:text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">Alphavedic Skill Development</h3>
          <p class="text-xs md:text-sm text-[var(--color-neon-pulse)] mb-2" style="font-family: var(--font-aeonik);">Ages 8 to 14</p>
          <p class="text-[12px] md:text-[var(--text-body)] text-[var(--color-slate-text)] leading-[var(--leading-body)] grow" style="font-family: var(--font-aeonik);">Abacus & Finger Math program to boost mental arithmetic and cognitive skills.</p>
        </div>
      </div>
    </section>

  </div>
</Layout>
