---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | Eklavya Tuition Classes" description="Learn about Eklavya Tuition Classes — established 2015 in Surat. Director Yogeshbhai Katariya. Std 1-12 Commerce coaching.">
  <div class="space-y-14 md:space-y-20">

    <section>
      <h1 class="font-medium leading-[var(--leading-display)] mb-6" style="font-family: var(--font-aeonikfono); font-size: var(--text-display); color: var(--color-pure-white);">
        About Us
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-slate-text)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-aeonik);">
        Established in 2015, Eklavya Tuition Classes (ETC) has been a trusted name in academic coaching for over a decade. Located in Utran, Surat, we provide focused, high-quality education for students from Class 1 to Class 12 (Commerce stream).
      </p>
    </section>

    <!-- Mission & Vision as glass cards -->
    <section class="grid md:grid-cols-2 gap-5">
      <div class="glass-card p-8 md:p-10">
        <div class="w-12 h-12 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-[var(--color-obsidian-shell)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <h2 class="text-[var(--text-heading-sm)] font-medium mb-4" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">Our Mission</h2>
        <p class="text-[var(--text-body)] text-[var(--color-slate-text)] leading-[var(--leading-body)]" style="font-family: var(--font-aeonik);">
          To provide every student with a strong academic foundation through personalized coaching, fostering both intellectual growth and character development — in Gujarati and English mediums.
        </p>
      </div>
      <div class="glass-card p-8 md:p-10">
        <div class="w-12 h-12 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-[var(--color-obsidian-shell)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h2 class="text-[var(--text-heading-sm)] font-medium mb-4" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">Our Vision</h2>
        <p class="text-[var(--text-body)] text-[var(--color-slate-text)] leading-[var(--leading-body)]" style="font-family: var(--font-aeonik);">
          To be the most trusted tuition center in Surat — known for academic excellence, dedicated faculty, and an environment where every child's future is guaranteed.
        </p>
      </div>
    </section>

    <!-- Our Story -->
    <section>
      <h2 class="text-[var(--text-heading)] font-medium leading-[var(--leading-heading)] mb-8" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Our Story
      </h2>
      <div class="bg-[var(--surface-deep-card)] rounded-[var(--radius-cards)] neon-border p-8 md:p-12">
        <div class="flex items-start gap-4 md:gap-6 mb-6">
          <div class="w-12 h-12 bg-[rgba(61,220,145,0.1)] rounded-full flex items-center justify-center shrink-0">
            <span class="text-[var(--color-neon-pulse)] text-lg font-bold" style="font-family: var(--font-aeonikfono);">2015</span>
          </div>
          <div>
            <p class="text-[var(--text-body)] text-[var(--color-slate-text)] leading-relaxed" style="font-family: var(--font-aeonik);">
              Founded by <strong class="text-[var(--color-pure-white)]">Yogeshbhai Katariya (M.Com, B.Ed)</strong> with 11 years of experience, Eklavya Tuition Classes began as a small initiative that has grown into a thriving learning community. Over the past 11 years, we have taught over 9,000 students and earned the trust of 18,000+ parents.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4 md:gap-6 mb-6">
          <div class="w-12 h-12 bg-[rgba(61,220,145,0.1)] rounded-full flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-[var(--color-neon-pulse)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <p class="text-[var(--text-body)] text-[var(--color-slate-text)] leading-relaxed" style="font-family: var(--font-aeonik);">
              Located at 310, 3rd Floor, Angel Square, Near Silver Business Point, VIP Circle, Utran, Surat — our centre is equipped with AC classrooms, digital boards, CCTV surveillance, and AI-powered teaching tools.
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4 md:gap-6">
          <div class="w-12 h-12 bg-[rgba(61,220,145,0.1)] rounded-full flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-[var(--color-neon-pulse)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <div>
            <p class="text-[var(--text-body)] text-[var(--color-slate-text)] leading-relaxed" style="font-family: var(--font-aeonik);">
              We offer coaching in Gujarati and English mediums, from Std 1 through Std 12 Commerce. Our team of 12+ dedicated faculty members covers all subjects with a strategic focus on board exam preparation, weekly tests, and pre-provided booklets with past papers.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Director -->
    <section class="glass-card p-10 md:p-14 text-center">
      <div class="w-20 h-20 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center mx-auto mb-5 border-2 border-[rgba(61,220,145,0.3)]">
        <span class="text-[var(--color-obsidian-shell)] text-2xl font-bold" style="font-family: var(--font-aeonikfono);">YK</span>
      </div>
      <h2 class="text-[var(--text-heading-sm)] font-medium mb-1" style="font-family: var(--font-aeonikfono); color: var(--color-pure-white);">
        Yogeshbhai Katariya
      </h2>
      <p class="text-sm text-[var(--color-neon-pulse)] font-medium mb-4" style="font-family: var(--font-aeonik);">M.Com, B.Ed — 11 Years Experience</p>
      <p class="text-[var(--text-body)] text-[var(--color-slate-text)] max-w-xl mx-auto leading-relaxed" style="font-family: var(--font-aeonik);">
        "Eklavya — Where trust, education and future are guaranteed!"
      </p>
    </section>

  </div>
</Layout>
