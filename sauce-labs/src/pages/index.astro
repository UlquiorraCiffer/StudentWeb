<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sauce Labs - Test Automation Platform</title>
  <link rel="stylesheet" href="../styles.css" />
</head>
<body>
  <Layout>
    <div class="space-y-12">
      <section class="text-center py-20">
        <h1 class="text-[--text-display] font-sans font-medium leading-[--leading-display] mb-6">
          Sauce Labs
        </h1>
        <p class="text-[--text-body-lg] text-[var(--color-slate-text)] max-w-2xl mx-auto leading-[--leading-body-lg]">
          Neon-lit engineering console for comprehensive test automation and continuous testing across every platform.
        </p>
        <div class="mt-8 flex gap-4 justify-center">
          <button class="bg-[var(--color-neon-pulse)] text-[var(--color-obsidian-shell)] px-8 py-3 rounded-full font-medium">Start Free Trial</button>
          <button class="border border-[var(--color-neon-pulse)] text-[var(--color-neon-pulse)] px-8 py-3 rounded-full font-medium">View Demo</button>
        </div>
      </section>

      <section class="rounded-3xl p-12" style="background: linear-gradient(135deg, var(--color-obsidian-shell) 0%, var(--color-deep-abyss) 100%);">
        <h2 class="text-[--text-heading-lg] font-sans font-medium mb-8 text-[var(--color-neon-pulse)]">Platform Features</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-[var(--surface-white-panel)] p-8 rounded-2xl shadow-[--shadow-md] border border-[var(--color-fog-border)]">
            <div class="w-12 h-12 bg-[var(--color-mint-whisper)] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[var(--color-neon-pulse)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 7h6m-6 4h6m2 5H7a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v11a2 2 0 01-2 2zM5 18h14a2 2 0 002-2v-7H3v7a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-[--text-heading-sm] font-medium mb-2 text-[var(--color-obsidian-shell)]">Test Automation</h3>
            <p class="text-[var(--color-slate-text)]">Comprehensive test automation across web, mobile, and desktop applications.</p>
          </div>
          <div class="bg-[var(--surface-white-panel)] p-8 rounded-2xl shadow-[--shadow-md] border border-[var(--color-fog-border)]">
            <div class="w-12 h-12 bg-[var(--color-signal-yellow)] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[var(--color-obsidian-shell)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-[--text-heading-sm] font-medium mb-2 text-[var(--color-obsidian-shell)]">Continuous Testing</h3>
            <p class="text-[var(--color-slate-text)]">Integrate testing into your CI/CD pipeline with real-time reporting.</p>
          </div>
          <div class="bg-[var(--surface-white-panel)] p-8 rounded-2xl shadow-[--shadow-md] border border-[var(--color-fog-border)]">
            <div class="w-12 h-12 bg-[var(--color-mint-whisper)] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[var(--color-obsidian-shell)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009.172 8.172L8 9 7 8 6 7H3m3 6h6"></path>
              </svg>
            </div>
            <h3 class="text-[--text-heading-sm] font-medium mb-2 text-[var(--color-obsidian-shell)]">Cross-Platform</h3>
            <p class="text-[var(--color-slate-text)]">Test across browsers, devices, and operating systems simultaneously.</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-[--text-heading-lg] font-sans font-medium mb-8">Quick Start</h2>
        <div class="bg-[var(--surface-mint-card)] rounded-3xl p-12">
          <div class="flex items-center justify-between mb-8">
            <div>
              <h3 class="text-[--text-heading-sm] font-medium mb-2">Getting Started with Sauce Labs</h3>
              <p class="text-[var(--color-obsidian-shell)]">Follow these simple steps to begin your testing journey</p>
            </div>
            <button class="bg-[var(--color-neon-pulse)] text-[var(--color-obsidian-shell)] px-6 py-2 rounded-full font-medium">View Guide</button>
          </div>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center text-[var(--color-obsidian-shell)] font-bold">1</div>
              <div class="flex-1">
                <h4 class="font-medium mb-1 text-[var(--color-obsidian-shell)]">Create Your Account</h4>
                <p class="text-sm text-[var(--color-slate-text)]">Sign up for a free trial and access the testing console</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center text-[var(--color-obsidian-shell)] font-bold">2</div>
              <div class="flex-1">
                <h4 class="font-medium mb-1 text-[var(--color-obsidian-shell)]">Install Testing Framework</h4>
                <p class="text-sm text-[var(--color-slate-text)]">Download and configure your preferred testing framework</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-[var(--color-neon-pulse)] rounded-full flex items-center justify-center text-[var(--color-obsidian-shell)] font-bold">3</div>
              <div class="flex-1">
                <h4 class="font-medium mb-1 text-[var(--color-obsidian-shell)]">Run Your First Test</h4>
                <p class="text-sm text-[var(--color-slate-text)]">Execute your first automated test suite and see results</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </Layout>
</body>
</html>
