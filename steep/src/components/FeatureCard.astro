---
const { icon, title, description } = Astro.props;
---

<div class="bg-[var(--surface-card)] rounded-2xl shadow-[var(--shadow-subtle)] transition-transform duration-300 hover:scale-[1.02] card-grid-item">
  <div class="card-icon-wrap w-12 h-12 bg-[var(--color-apricot-wash)] rounded-full flex items-center justify-center mb-4">
    <span class="text-[var(--color-rust)]" set:html={icon}></span>
  </div>
  <h3 class="card-title text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-signifier); color: var(--color-ink);">
    {title}
  </h3>
  <p class="card-desc text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)]" style="font-family: var(--font-sohne);">
    {description}
  </p>
</div>
