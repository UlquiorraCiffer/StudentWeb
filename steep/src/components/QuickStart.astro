---
const steps = [
  { num: '01', title: 'Admission Enquiry', desc: 'Reach out via phone, in-person, or our enquiry form. We guide you through the process step by step.', color: 'var(--color-card-lavender)' },
  { num: '02', title: 'Choose Your Subjects', desc: 'Select from our wide range of subjects across Std 1-12 (Commerce). Gujarati & English mediums available.', color: 'var(--color-accent-green)' },
  { num: '03', title: 'Excel in Studies', desc: 'Join regular classes, access study materials, and benefit from our focused academic approach.', color: 'var(--color-card-pink)' },
];
---

<section>
  <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-12" style="font-family: var(--font-signifier); color: var(--color-ink); font-size: var(--text-heading);">
    How to Get Started
  </h2>
  <div class="bg-[var(--section-tint-mint)] rounded-3xl p-10 md:p-12">
    <div class="space-y-8">
      {steps.map(s => (
        <div class="flex items-start gap-6 transition-transform duration-300 hover:scale-[1.01]">
          <div class="w-12 h-12 rounded-full flex items-center justify-center text-[var(--color-pure-white)] font-bold text-lg shrink-0" style={`background: ${s.color}; font-family: var(--font-signifier);`}>
            {s.num}
          </div>
          <div>
            <h3 class="text-[var(--text-heading-sm)] font-medium mb-1" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
              {s.title}
            </h3>
            <p class="text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">
              {s.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
