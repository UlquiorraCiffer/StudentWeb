---
const { title, subtitle, ctaText, ctaLink } = Astro.props;
---

<section class="relative overflow-hidden rounded-3xl" style="background: linear-gradient(135deg, #fbe1d1 0%, #fff5ed 40%, #ffffff 100%);">
  <div class="max-w-[var(--page-max-width)] mx-auto px-6 py-24 md:py-32 text-center">
    <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-4" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
      {title}
    </h1>
    <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-2xl mx-auto leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne);">
      {subtitle}
    </p>
    <div class="mt-6 flex justify-center">
      <span class="inline-flex items-center gap-1.5 bg-[rgba(37,211,102,0.1)] text-[#1a9e4a] px-4 py-1.5 rounded-full text-sm font-semibold" style="font-family: var(--font-sohne);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Now AI-Powered
      </span>
    </div>
    <a href={ctaLink}>
      <button class="mt-10 bg-[var(--color-ink)] text-[var(--color-pure-white)] px-10 py-4 rounded-full text-base font-medium transition-opacity hover:opacity-85" style="font-family: var(--font-sohne);">
        {ctaText}
      </button>
    </a>
  </div>
</section>
