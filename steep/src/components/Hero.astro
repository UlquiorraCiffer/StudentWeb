---
import TextReveal from './TextReveal';
const { title, subtitle, ctaText, ctaLink } = Astro.props;
---

<section class="relative overflow-hidden rounded-3xl" style="background: linear-gradient(145deg, #fef3c8 0%, #fff8ef 40%, #fff8ef 60%, #fce0ef 100%);">
  <div class="relative z-10 max-w-[var(--page-max-width)] mx-auto px-6 py-24 md:py-32 text-center">
    <div class="relative">
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--color-card-saffron) 25%, transparent) 0%, transparent 60%);"></div>
      <div class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-4 relative" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-midnight-ink);">
        <TextReveal text={title} client:load />
      </div>
    </div>
    <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-2xl mx-auto leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne);">
      {subtitle}
    </p>
    <div class="mt-6 flex justify-center">
      <span class="inline-flex items-center gap-1.5 bg-[var(--color-card-saffron)] text-[var(--color-midnight-ink)] px-4 py-1.5 rounded-full text-sm font-medium" style="font-family: var(--font-sohne);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Now AI-Powered
      </span>
    </div>
    <a href={ctaLink}>
      <button class="mt-10 bg-[var(--color-accent-green)] text-[var(--color-midnight-ink)] px-10 py-4 rounded-full text-base font-medium transition-opacity hover:opacity-85" style="font-family: var(--font-sohne);">
        {ctaText}
      </button>
    </a>
  </div>
</section>
