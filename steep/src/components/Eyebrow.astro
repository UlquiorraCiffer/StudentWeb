---
const { text, icon, class: className = '' } = Astro.props;
---

<span
   class={`inline-flex items-center gap-1.5 text-[13px] font-medium uppercase tracking-[0.1em] text-[var(--color-midnight-ink)] mb-2 ${className}`}
  style="font-family: var(--font-sohne);"
>
  {icon && <span set:html={icon} />}
  {text}
</span>
