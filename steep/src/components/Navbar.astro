---
const { currentPath = '/' } = Astro.props;

const pages = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/courses', label: 'Courses' },
  { href: '/faculty', label: 'Faculty' },
  { href: '/facilities', label: 'Facilities' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-[var(--surface-canvas)] border-b border-[var(--color-dove)]">
  <nav class="max-w-[var(--page-max-width)] mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-xl font-medium text-[var(--color-ink)] flex items-center gap-2" style="font-family: var(--font-signifier);">
      Eklavya
      <span class="nav-ai-badge hidden sm:inline-flex">&#9889; AI-Powered</span>
    </a>

    <div class="hidden md:flex gap-8 text-sm" style="font-family: var(--font-sohne);">
      {pages.map(p => {
        const isActive = (p.href === '/' ? currentPath === '/' : currentPath.startsWith(p.href));
        return (
          <a
            href={p.href}
            class={`transition-colors ${isActive ? 'text-[var(--color-ink)] font-medium' : 'text-[var(--color-graphite)] hover:text-[var(--color-ink)]'}`}
          >
            {p.label}
          </a>
        );
      })}
    </div>

    <a href="/contact" class="hidden md:inline-block">
      <button class="bg-[var(--color-ink)] text-[var(--color-pure-white)] px-6 py-2.5 rounded-full text-sm font-medium transition-opacity hover:opacity-85 min-h-[44px]" style="font-family: var(--font-sohne);">
        Enquire Now
      </button>
    </a>

  </nav>
</header>
