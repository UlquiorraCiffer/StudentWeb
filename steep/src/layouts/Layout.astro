---
import '../styles.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const { title = 'Eklavya Tuition Classes', description = 'Dedicated to academic excellence — coaching from Class 1 through Class 10 in Telugu & English mediums.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preload" href="/fonts/Signifier-Regular.otf" as="font" type="font/otf" crossorigin />
  <link rel="preload" href="/fonts/Sohne-Regular.otf" as="font" type="font/otf" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen bg-[var(--surface-canvas)] text-[var(--color-ink)] antialiased" style="font-family: var(--font-sohne);">
  <Navbar />
  <main class="max-w-[var(--page-max-width)] mx-auto px-6 py-12">
    <slot />
  </main>
  <Footer />
</body>
</html>
