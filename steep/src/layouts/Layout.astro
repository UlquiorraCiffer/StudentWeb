---
import '../styles.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const { title = 'Eklavya Tuition Classes', description = 'Eklavya Tuition Classes — Std 1 to 12 (Commerce) coaching in Surat. Gujarati & English medium. 9,000+ students taught. Where trust, education and future are guaranteed!' } = Astro.props;

const currentPath = Astro.url.pathname;
const bottomTabs = [
  { href: '/', label: 'Home', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>' },
  { href: '/courses', label: 'Courses', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>' },
  { href: '/faculty', label: 'Faculty', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>' },
  { href: '/contact', label: 'Contact', icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preload" href="/fonts/Signifier-Regular.otf" as="font" type="font/otf" crossorigin />
  <link rel="preload" href="/fonts/Sohne-Regular.otf" as="font" type="font/otf" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen bg-[var(--surface-canvas)] text-[var(--color-ink)] antialiased" style="font-family: var(--font-sohne);">
  <Navbar currentPath={Astro.url.pathname} />
  <main class="max-w-[var(--page-max-width)] mx-auto px-6 py-12">
    <slot />
  </main>
  <Footer />

  <!-- Mobile bottom nav -->
  <nav class="fixed bottom-0 left-0 right-0 z-50 bg-[var(--surface-canvas)] border-t border-[var(--color-dove)] shadow-[0_-2px_10px_rgba(0,0,0,0.04)] md:hidden" style="padding-bottom: env(safe-area-inset-bottom, 0px);">
    <div class="flex items-center justify-around py-1">
      {bottomTabs.map(t => {
        const isActive = t.href === '/' ? currentPath === '/' : currentPath.startsWith(t.href);
        <a
          href={t.href}
          class={`flex flex-col items-center gap-0.5 px-3 py-1.5 min-w-[64px] min-h-[48px] justify-center transition-colors ${isActive ? 'text-[var(--color-rust)]' : 'text-[var(--color-graphite)] hover:text-[var(--color-ink)]'}`}
          style="font-family: var(--font-sohne);"
        >
          <span class={isActive ? 'text-[var(--color-rust)]' : ''} set:html={t.icon}>
          </span>
          <span class="text-[10px] leading-tight font-medium">{t.label}</span>
        </a>
      })}
    </div>
  </nav>

  <a
    href="https://wa.me/919586571876"
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-float"
    aria-label="Chat on WhatsApp"
  >
    <svg class="w-7 h-7 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</body>
</html>
