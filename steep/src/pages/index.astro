<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Steep Dashboard - Daylight Analytics</title>
  <link rel="stylesheet" href="../styles.css" />
</head>
<body>
  <Layout>
    <div class="space-y-12">
      <section class="text-center py-20">
        <h1 class="text-[--text-display] font-serif font-normal leading-[--leading-display] tracking-[--tracking-display] mb-6">
          Steep Analytics
        </h1>
        <p class="text-[--text-body-lg] text-[var(--color-ash)] max-w-2xl mx-auto leading-[--leading-body-lg]">
          Daylight analytics workspace with warm peach accents and editorial typography for confident decision-making.
        </p>
        <div class="mt-8 flex gap-4 justify-center">
          <button class="bg-[var(--color-ink)] text-[var(--color-pure-white)] px-8 py-3 rounded-full font-medium">Get Started</button>
          <button class="border border-[var(--color-dove)] text-[var(--color-ink)] px-8 py-3 rounded-full font-medium">View Demo</button>
        </div>
      </section>

      <section class="bg-[var(--surface-fog)] rounded-3xl p-12">
        <h2 class="text-[--text-heading-lg] font-serif font-normal mb-8">Platform Features</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-[var(--surface-card)] p-8 rounded-2xl shadow-[--shadow-subtle]">
            <div class="w-12 h-12 bg-[var(--color-apricot-wash)] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[var(--color-rust)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <h3 class="text-[--text-heading-sm] font-medium mb-2">Analytics</h3>
            <p class="text-[var(--color-graphite)]">Real-time data visualization with warm-toned charts and statistical insights.</p>
          </div>
          <div class="bg-[var(--surface-card)] p-8 rounded-2xl shadow-[--shadow-subtle]">
            <div class="w-12 h-12 bg-[var(--color-sky-wash)] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[var(--color-ink)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-[--text-heading-sm] font-medium mb-2">Automation</h3>
            <p class="text-[var(--color-graphite)]">Scheduled reporting with customizable data pipelines and integration.</p>
          </div>
          <div class="bg-[var(--surface-card)] p-8 rounded-2xl shadow-[--shadow-subtle]">
            <div class="w-12 h-12 bg-[var(--color-apricot-wash)] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[var(--color-ink)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20H2v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-[--text-heading-sm] font-medium mb-2">Collaboration</h3>
            <p class="text-[var(--color-graphite)]">Team workspaces with role-based access and shared dashboards.</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-[--text-heading-lg] font-serif font-normal mb-8">Quick Start</h2>
        <div class="bg-[var(--surface-warm-tint)] rounded-3xl p-12">
          <div class="flex items-center justify-between mb-8">
            <div>
              <h3 class="text-[--text-heading-sm] font-medium mb-2">Getting Started with Steep</h3>
              <p class="text-[var(--color-ink)]">Follow these simple steps to begin your analytics journey</p>
            </div>
            <button class="bg-[var(--color-ink)] text-[var(--color-pure-white)] px-6 py-2 rounded-full font-medium">View Guide</button>
          </div>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-[var(--color-rust)] rounded-full flex items-center justify-center text-[var(--color-pure-white)] font-bold">1</div>
              <div class="flex-1">
                <h4 class="font-medium mb-1">Create Your Account</h4>
                <p class="text-sm text-[var(--color-graphite)]">Sign up for a free trial and access the dashboard</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-[var(--color-rust)] rounded-full flex items-center justify-center text-[var(--color-pure-white)] font-bold">2</div>
              <div class="flex-1">
                <h4 class="font-medium mb-1">Connect Data Sources</h4>
                <p class="text-sm text-[var(--color-graphite)]">Import data from APIs, databases, or CSV files</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 bg-[var(--color-rust)] rounded-full flex items-center justify-center text-[var(--color-pure-white)] font-bold">3</div>
              <div class="flex-1">
                <h4 class="font-medium mb-1">Build Your First Dashboard</h4>
                <p class="text-sm text-[var(--color-graphite)]">Drag-and-drop widgets and create beautiful reports</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </Layout>
</body>
</html>
