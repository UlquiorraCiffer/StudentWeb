---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import QuickStart from '../components/QuickStart.astro';
import FeatureCard from '../components/FeatureCard.astro';
---

<Layout>
  <div class="space-y-16">
    <Hero
      title="Eklavya"
      subtitle="Dedicated to academic excellence since 2009. Nurturing young minds from Class 1 through Class 10 with personalized attention and a proven track record."
      ctaText="Enquire Now"
      ctaLink="/contact"
    />

    <StatsBar />

    <section>
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-12" style="font-family: var(--font-signifier); color: var(--color-ink); font-size: var(--text-heading);">
        Why Choose Eklavya
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <FeatureCard
          icon="<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z'/></svg>"
          title="Small Batch Sizes"
          description="Every student gets individual attention. Our small class sizes ensure no one is left behind."
        />
        <FeatureCard
          icon="<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z'/></svg>"
          title="Proven Results"
          description="Consistent academic improvement across all subjects with regular assessments and feedback."
        />
        <FeatureCard
          icon="<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M3 21h18M3 10h18M3 7l9-4 9 4M4 10v11m16-11v11M8 14v.5m8-.5v.5M8 18v.5m8-.5v.5'/></svg>"
          title="Dual Medium"
          description="Classes available in both Telugu and English mediums catering to diverse student needs."
        />
        <FeatureCard
          icon="<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'/></svg>"
          title="All Subjects"
          description="Comprehensive coverage of Mathematics, Science, Social, English, Telugu, Hindi, and more."
        />
        <FeatureCard
          icon="<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'/></svg>"
          title="Digital Resources"
          description="Modern teaching aids, digital content, and smart classroom tools to enhance learning."
        />
        <FeatureCard
          icon="<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 14l9-5-9-5-9 5 9 5z'/><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z'/></svg>"
          title="Experienced Faculty"
          description="Qualified teachers with 15+ years of combined experience dedicated to student success."
        />
      </div>
    </section>

    <QuickStart />

    <section class="bg-[var(--surface-warm-tint)] rounded-3xl p-12 text-center">
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-6" style="font-family: var(--font-signifier); color: var(--color-ink); font-size: var(--text-heading);">
        Our Success Mantra
      </h2>
      <blockquote class="text-[var(--text-heading-sm)] text-[var(--color-rust)] max-w-3xl mx-auto leading-relaxed italic" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm);">
        "Every child is unique. We don't just teach — we mentor, guide, and inspire. Our goal is not just good grades, but confident, curious, and capable individuals."
      </blockquote>
    </section>
  </div>
</Layout>
