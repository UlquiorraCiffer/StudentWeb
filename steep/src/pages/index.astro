---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import QuickStart from '../components/QuickStart.astro';
import FeatureCard from '../components/FeatureCard.astro';
---

<Layout>
  <div class="space-y-16">
    <Hero
      title="Eklavya"
      subtitle="Dedicated to academic excellence since 2009. Nurturing young minds from Class 1 through Class 10 with personalized attention and a proven track record."
      ctaText="Enquire Now"
      ctaLink="/contact"
    />

    <StatsBar />

    <section>
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-12" style="font-family: var(--font-signifier); color: var(--color-ink); font-size: var(--text-heading);">
        Why Choose Eklavya
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <FeatureCard
          icon="&#9776;"
          title="Small Batch Sizes"
          description="Every student gets individual attention. Our small class sizes ensure no one is left behind."
        />
        <FeatureCard
          icon="&#9733;"
          title="Proven Results"
          description="Consistent academic improvement across all subjects with regular assessments and feedback."
        />
        <FeatureCard
          icon="&#9998;"
          title="Dual Medium"
          description="Classes available in both Telugu and English mediums catering to diverse student needs."
        />
        <FeatureCard
          icon="&#128218;"
          title="All Subjects"
          description="Comprehensive coverage of Mathematics, Science, Social, English, Telugu, Hindi, and more."
        />
        <FeatureCard
          icon="&#128640;"
          title="Digital Resources"
          description="Modern teaching aids, digital content, and smart classroom tools to enhance learning."
        />
        <FeatureCard
          icon="&#128101;"
          title="Experienced Faculty"
          description="Qualified teachers with 15+ years of combined experience dedicated to student success."
        />
      </div>
    </section>

    <QuickStart />

    <section class="bg-[var(--surface-warm-tint)] rounded-3xl p-12 text-center">
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-6" style="font-family: var(--font-signifier); color: var(--color-ink); font-size: var(--text-heading);">
        Our Success Mantra
      </h2>
      <blockquote class="text-[var(--text-heading-sm)] text-[var(--color-rust)] max-w-3xl mx-auto leading-relaxed italic" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm);">
        "Every child is unique. We don't just teach — we mentor, guide, and inspire. Our goal is not just good grades, but confident, curious, and capable individuals."
      </blockquote>
    </section>
  </div>
</Layout>
