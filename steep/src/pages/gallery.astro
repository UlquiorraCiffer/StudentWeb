---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';

const activityColors = [
  { bg: 'var(--color-card-saffron)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-lavender)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-mint)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-pink)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-highlight-yellow)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-saffron)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-lavender)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-mint)', iconColor: 'var(--color-midnight-ink)' },
];

const activities = [
  { title: 'Cultural Programs', desc: 'Sanskrutik Karyakram — Students showcase their talents through cultural performances, skits, and music.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M7 4V2m0 2v2m0-2H5m2 0h2m4 0h2m-2 0V2m0 2v2m7-2l-3 3m0 0l-3-3m3 3V2M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12v6a2 2 0 002 2h10a2 2 0 002-2v-6'/></svg>" },
  { title: 'Ganesh Festival', desc: 'Annual Ganesh Chaturthi celebration with students, faculty, and the Eklavya community.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'/></svg>" },
  { title: 'Sports Day', desc: 'Annual sports events encouraging physical fitness, teamwork, and healthy competition among students.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'/></svg>" },
  { title: 'Republic Day', desc: '26th January celebration with flag hoisting, patriotic programs, and student-led activities.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M3 21h18M3 10h18m-9-9l9 4-9 4-9-4 9-4z'/></svg>" },
  { title: 'Award Ceremonies', desc: 'Inam Dwara Samman — Recognizing student achievements with awards and certificates of excellence.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z'/></svg>" },
  { title: 'Parent-Teacher Meetings', desc: 'Vali Meeting — Regular parent-teacher interactions to discuss student progress and development.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z'/></svg>" },
  { title: "Teachers' Day", desc: 'Celebrating our dedicated faculty with special events and student appreciation programs.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'/></svg>" },
  { title: 'Rangoli Competition', desc: 'Colorful Rangoli competitions that nurture creativity and artistic expression among students.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01'/></svg>" },
];
---

<Layout title="Gallery | Eklavya Tuition Classes" description="Student activities at Eklavya Tuition Classes — cultural programs, sports, festivals, award ceremonies, and more in Surat." atmosphere="warm">
  <div class="space-y-12 md:space-y-16">

    <section>
      <Eyebrow text="// GALLERY" />
      <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
        Student Life
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne); font-size: var(--text-body-lg);">
        At Eklavya, learning goes beyond textbooks. We celebrate culture, achievement, and community through a variety of activities throughout the year.
      </p>
    </section>

    <section class="card-grid grid grid-cols-2 lg:grid-cols-4 gap-2 md:gap-6 lg:gap-8">
      {activities.map((a, i) => (
        <div class="rounded-2xl transition-transform duration-300 hover:scale-[1.02] flex flex-col p-3 md:p-6 lg:p-8" style={`background: color-mix(in srgb, ${activityColors[i].bg} 10%, white); border-top: 3px solid ${activityColors[i].bg};`}>
          <div class="w-10 h-10 md:w-14 md:h-14 rounded-full flex items-center justify-center mx-auto mb-3 md:mb-4 shrink-0 card-icon" style={`background: ${activityColors[i].bg};`}>
            <span style={`color: ${activityColors[i].iconColor};`} set:html={a.icon}></span>
          </div>
          <h3 class="text-[13px] md:text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-signifier); color: var(--color-ink);">
            {a.title}
          </h3>
          <p class="text-[11px] md:text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)] grow card-desc" style="font-family: var(--font-sohne);">
            {a.desc}
          </p>
        </div>
      ))}
    </section>

  </div>
</Layout>
