---
import Layout from '../layouts/Layout.astro';

const activities = [
  { title: 'Annual Day Celebrations', desc: 'Students showcase their talents through cultural programs, skits, and performances.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M7 4V2m0 2v2m0-2H5m2 0h2m4 0h2m-2 0V2m0 2v2m7-2l-3 3m0 0l-3-3m3 3V2M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12v6a2 2 0 002 2h10a2 2 0 002-2v-6'/></svg>" },
  { title: 'Science Exhibitions', desc: 'Hands-on projects and experiments that bring scientific concepts to life.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'/></svg>" },
  { title: 'Quiz Competitions', desc: 'Regular quiz events that build knowledge, confidence, and quick thinking.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z'/></svg>" },
  { title: 'Art & Craft Sessions', desc: 'Creative activities that nurture imagination and artistic expression.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01'/></svg>" },
  { title: 'Sports & Games', desc: 'Physical activities and indoor games for holistic development.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'/></svg>" },
  { title: 'Study Groups & Workshops', desc: 'Collaborative learning sessions and subject-specific workshops.', icon: "<svg class='w-8 h-8' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z'/></svg>" },
];
---

<Layout title="Gallery | Eklavya Tuition Classes" description="Student life at Eklavya Tuition Classes — co-curricular activities, events, and learning environment.">
  <div class="space-y-16">

    <section>
      <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
        Student Life
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne); font-size: var(--text-body-lg);">
        At Eklavya, learning goes beyond textbooks. We encourage students to explore, create, and grow through a variety of co-curricular activities.
      </p>
    </section>

    <section class="grid md:grid-cols-3 gap-8">
      {activities.map(a => (
        <div class="bg-[var(--surface-fog)] rounded-3xl p-8 text-center transition-transform duration-300 hover:scale-[1.02]">
          <div class="w-14 h-14 bg-[var(--color-apricot-wash)] rounded-full flex items-center justify-center mx-auto mb-5">
            <span class="text-[var(--color-rust)]" set:html={a.icon}></span>
          </div>
          <h3 class="text-[var(--text-heading-sm)] font-medium mb-3" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
            {a.title}
          </h3>
          <p class="text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">
            {a.desc}
          </p>
        </div>
      ))}
    </section>

    <section class="bg-[var(--surface-warm-tint)] rounded-3xl p-12">
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-6 text-center" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Learning Environment
      </h2>
      <div class="grid md:grid-cols-3 gap-6 text-center">
        <div class="bg-[var(--surface-card)] rounded-2xl p-6 shadow-[var(--shadow-subtle)]">
          <p class="text-lg font-medium text-[var(--color-ink)]" style="font-family: var(--font-signifier);">Interactive Classes</p>
          <p class="text-sm text-[var(--color-graphite)] mt-2" style="font-family: var(--font-sohne);">Engaging lessons with active student participation</p>
        </div>
        <div class="bg-[var(--surface-card)] rounded-2xl p-6 shadow-[var(--shadow-subtle)]">
          <p class="text-lg font-medium text-[var(--color-ink)]" style="font-family: var(--font-signifier);">Regular Testing</p>
          <p class="text-sm text-[var(--color-graphite)] mt-2" style="font-family: var(--font-sohne);">Weekly tests and periodic assessments to track progress</p>
        </div>
        <div class="bg-[var(--surface-card)] rounded-2xl p-6 shadow-[var(--shadow-subtle)]">
          <p class="text-lg font-medium text-[var(--color-ink)]" style="font-family: var(--font-signifier);">Parent Meetings</p>
          <p class="text-sm text-[var(--color-graphite)] mt-2" style="font-family: var(--font-sohne);">Regular parent-teacher interactions to discuss progress</p>
        </div>
      </div>
    </section>

  </div>
</Layout>
