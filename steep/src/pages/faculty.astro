---
import Layout from '../layouts/Layout.astro';
import FacultyTooltip from '../components/FacultyTooltip';
import Eyebrow from '../components/Eyebrow.astro';
import HaloHeading from '../components/HaloHeading.astro';

const subjectColors: Record<string, { bg: string; iconColor: string }> = {
  English: { bg: 'var(--color-card-saffron)', iconColor: 'var(--color-midnight-ink)' },
  'Social Science': { bg: 'var(--color-card-pink)', iconColor: 'var(--color-midnight-ink)' },
  Science: { bg: 'var(--color-card-lavender)', iconColor: 'var(--color-midnight-ink)' },
  Mathematics: { bg: 'var(--color-card-mint)', iconColor: 'var(--color-midnight-ink)' },
  Gujarati: { bg: 'var(--color-highlight-yellow)', iconColor: 'var(--color-midnight-ink)' },
  Sanskrit: { bg: 'var(--color-card-pink)', iconColor: 'var(--color-midnight-ink)' },
  Accounts: { bg: 'var(--color-card-mint)', iconColor: 'var(--color-midnight-ink)' },
  Statistics: { bg: 'var(--color-card-lavender)', iconColor: 'var(--color-midnight-ink)' },
  Economics: { bg: 'var(--color-card-saffron)', iconColor: 'var(--color-midnight-ink)' },
  'B.A.': { bg: 'var(--color-highlight-yellow)', iconColor: 'var(--color-midnight-ink)' },
};

const std10Faculty = [
  { name: 'Hardik Sir', role: 'Std 10 & 12 English Faculty', subjects: 'English', initials: 'H' },
  { name: 'Ankit Sir', role: 'Std 10 Social Science Faculty', subjects: 'Social Science', initials: 'A' },
  { name: 'Devendra Sir', role: 'Std 10 Science Faculty', subjects: 'Science', initials: 'D' },
  { name: 'Sagar Sir', role: 'Std 10 Maths Faculty', subjects: 'Mathematics', initials: 'S' },
  { name: 'Suresh Sir', role: 'Std 10 & 12 Gujarati Faculty', subjects: 'Gujarati', initials: 'SU' },
  { name: 'Helvin Sir', role: 'Std 10 Sanskrit Faculty', subjects: 'Sanskrit', initials: 'HE' },
];

const std12Faculty = [
  { name: 'Arthik Sir', role: 'Std 12 Commerce Faculty', subjects: 'Accounts', initials: 'AR' },
  { name: 'Yogesh Sir', role: 'Std 12 Commerce Faculty', subjects: 'Statistics', initials: 'Y' },
  { name: 'Deepak Sir', role: 'Std 12 Commerce Faculty', subjects: 'Economics', initials: 'DE' },
  { name: 'Vijay Sir', role: 'Std 12 Commerce Faculty', subjects: 'B.A.', initials: 'V' },
];

function getSubjectColor(subject: string) {
  return subjectColors[subject] || { bg: 'var(--color-card-saffron)', iconColor: 'var(--color-midnight-ink)' };
}
---

<Layout title="Faculty | Eklavya Tuition Classes" description="Meet our dedicated faculty at Eklavya Tuition Classes — experienced teachers for Std 10 and Std 12 Commerce." atmosphere="lavender">
  <div class="space-y-12 md:space-y-16">

    <section>
      <Eyebrow text="// FACULTY" />
      <HaloHeading>
        <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
          Our Faculty
        </h1>
      </HaloHeading>
      <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne); font-size: var(--text-body-lg);">
        Meet the dedicated educators behind Eklavya's success. Led by Director <strong>Yogeshbhai Katariya (M.Com, B.Ed)</strong> — 11 years of experience.
      </p>
    </section>

    <section>
      <Eyebrow text="// STD 10" />
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Std 10 Teachers
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-2 md:gap-6 lg:gap-8">
        {std10Faculty.map(f => {
          const c = getSubjectColor(f.subjects);
          return (
            <div class="bg-[var(--section-tint-lavender)] rounded-3xl p-3 md:p-6 lg:p-8 flex flex-col md:flex-row items-center md:items-start gap-3 md:gap-5 transition-transform duration-300 hover:scale-[1.02]">
              <FacultyTooltip name={f.name} role={f.role} initials={f.initials} bg={c.bg} iconColor={c.iconColor} client:load />
              <div class="grow text-center md:text-left">
                <h3 class="text-[13px] md:text-[var(--text-heading-sm)] font-medium" style="font-family: var(--font-signifier); color: var(--color-ink);">{f.name}</h3>
                <p class="text-[11px] md:text-sm text-[var(--color-midnight-ink)] mt-1" style="font-family: var(--font-sohne);">{f.role}</p>
                <p class="text-[11px] md:text-sm text-[var(--color-graphite)] mt-1" style="font-family: var(--font-sohne);">Subject: {f.subjects}</p>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section>
      <Eyebrow text="// STD 12 COMMERCE" />
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Std 12 Commerce Teachers
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-2 md:gap-6 lg:gap-8">
        {std12Faculty.map(f => {
          const c = getSubjectColor(f.subjects);
          return (
            <div class="bg-[var(--section-tint-lavender)] rounded-3xl p-3 md:p-6 lg:p-8 flex flex-col md:flex-row items-center md:items-start gap-3 md:gap-5 transition-transform duration-300 hover:scale-[1.02]">
              <FacultyTooltip name={f.name} role={f.role} initials={f.initials} bg={c.bg} iconColor={c.iconColor} client:load />
              <div class="grow text-center md:text-left">
                <h3 class="text-[13px] md:text-[var(--text-heading-sm)] font-medium" style="font-family: var(--font-signifier); color: var(--color-ink);">{f.name}</h3>
                <p class="text-[11px] md:text-sm text-[var(--color-midnight-ink)] mt-1" style="font-family: var(--font-sohne);">{f.role}</p>
                <p class="text-[11px] md:text-sm text-[var(--color-graphite)] mt-1" style="font-family: var(--font-sohne);">Subject: {f.subjects}</p>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="bg-[var(--section-tint-mint)] rounded-3xl p-12 text-center">
      <Eyebrow text="// DIRECTOR" class="justify-center" />
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-4" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Director
      </h2>
      <div class="w-20 h-20 bg-[var(--color-card-lavender)] rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="text-[var(--color-midnight-ink)] text-2xl font-bold" style="font-family: var(--font-signifier);">YK</span>
      </div>
      <h3 class="text-[var(--text-heading-sm)] font-medium" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
        Yogeshbhai Katariya
      </h3>
      <p class="text-sm text-[var(--color-midnight-ink)] font-medium mt-1" style="font-family: var(--font-sohne);">M.Com, B.Ed — 11 Years Experience</p>
      <p class="text-[var(--text-body)] text-[var(--color-ink)] max-w-2xl mx-auto mt-4 leading-relaxed" style="font-family: var(--font-sohne); font-size: var(--text-body);">
        "Eklavya — Where trust, education and future are guaranteed!"
      </p>
    </section>

  </div>
</Layout>
