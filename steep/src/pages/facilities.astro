---
import Layout from '../layouts/Layout.astro';

const facilities = [
  { title: 'AC Classrooms', icon: '&#9926;', description: 'Fully air-conditioned classrooms providing a comfortable learning environment throughout the year.' },
  { title: 'Library', icon: '&#128218;', description: 'In-house library with reference books, textbooks, and supplementary reading material for all grades.' },
  { title: 'Digital Resources', icon: '&#128187;', description: 'Smart teaching aids, digital content, and multimedia tools used alongside traditional teaching methods.' },
  { title: 'Transport Support', icon: '&#128652;', description: 'Located in a convenient, accessible area near major landmarks for easy drop-off and pickup.' },
  { title: 'Safe Environment', icon: '&#128737;', description: 'Secure premises with proper supervision ensuring student safety at all times.' },
  { title: 'Clean Facilities', icon: '&#128167;', description: 'Well-maintained sanitation facilities and clean drinking water for all students.' },
];
---

<Layout title="Facilities | Eklavya Tuition Classes" description="Explore the facilities at Eklavya Tuition Classes — AC classrooms, library, digital resources, and more.">
  <div class="space-y-16">

    <section>
      <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
        Facilities
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne); font-size: var(--text-body-lg);">
        We provide a supportive and well-equipped environment that enhances the learning experience for every student.
      </p>
    </section>

    <section class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {facilities.map(f => (
        <div class="bg-[var(--surface-card)] p-8 rounded-2xl shadow-[var(--shadow-subtle)] border border-[var(--color-fog)]">
          <div class="w-12 h-12 bg-[var(--color-apricot-wash)] rounded-full flex items-center justify-center mb-4">
            <span class="text-[var(--color-rust)] text-xl" set:html={f.icon}></span>
          </div>
          <h3 class="text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
            {f.title}
          </h3>
          <p class="text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">
            {f.description}
          </p>
        </div>
      ))}
    </section>

  </div>
</Layout>
