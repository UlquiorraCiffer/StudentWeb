---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Eklavya Tuition Classes" description="Contact Eklavya Tuition Classes at Utran, Surat. Call 09054515619 / 95865 71876. Visit 310, Angel Square, VIP Circle.">
  <div class="space-y-12 md:space-y-16">

    <section>
      <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
        Contact Us
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne); font-size: var(--text-body-lg);">
        Have questions or want to enrol your child? Reach out to us — we're happy to help.
      </p>
    </section>

    <div class="grid md:grid-cols-2 gap-12">
      <section>
        <div class="bg-[var(--surface-fog)] rounded-3xl p-10 space-y-6">
          <div>
            <h3 class="text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider mb-2" style="font-family: var(--font-sohne);">
              <svg class="w-4 h-4 inline mr-2 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Address
            </h3>
            <p class="text-[var(--color-graphite)] leading-relaxed pl-7" style="font-family: var(--font-sohne); font-size: var(--text-body);">
              310, 3rd Floor, Angel Square,<br />
              Near Silver Business Point, VIP Circle,<br />
              Utran, Surat — 394105, Gujarat
            </p>
          </div>
          <div>
            <h3 class="text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider mb-2" style="font-family: var(--font-sohne);">
              <svg class="w-4 h-4 inline mr-2 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Phone
            </h3>
            <p class="pl-7" style="font-family: var(--font-sohne); font-size: var(--text-body);">
              <a href="tel:+919054515619" class="text-[var(--color-rust)] hover:underline">09054515619</a><br />
              <a href="tel:+919586571876" class="text-[var(--color-rust)] hover:underline">95865 71876</a>
            </p>
          </div>
          <div>
            <h3 class="text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider mb-2" style="font-family: var(--font-sohne);">
              <svg class="w-4 h-4 inline mr-2 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Timings
            </h3>
            <p class="text-[var(--color-graphite)] pl-7" style="font-family: var(--font-sohne); font-size: var(--text-body);">
              Mon - Sat: Open until 8:00 PM<br />
              Sunday: Closed
            </p>
          </div>
          <div>
            <h3 class="text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider mb-2" style="font-family: var(--font-sohne);">
              <svg class="w-4 h-4 inline mr-2 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              WhatsApp
            </h3>
            <a href="https://wa.me/919586571876" target="_blank" class="inline-flex items-center gap-2 mt-1 bg-green-600 text-white px-5 py-2 rounded-full text-sm font-medium transition-opacity hover:opacity-85 ml-7" style="font-family: var(--font-sohne);">
              Chat on WhatsApp
            </a>
          </div>
        </div>
      </section>

      <section>
        <div class="bg-[var(--surface-card)] rounded-3xl p-10 shadow-[var(--shadow-subtle)] border border-[var(--color-fog)]">
          <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
            Enquiry Form
          </h2>
          <form id="enquiry-form" class="space-y-5" action="#" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium text-[var(--color-ink)] mb-1" style="font-family: var(--font-sohne);">Student Name *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-[var(--radius-inputs)] border border-[var(--color-dove)] bg-[var(--surface-canvas)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-apricot-wash)]" style="font-family: var(--font-sohne);" />
            </div>
            <div>
              <label for="grade" class="block text-sm font-medium text-[var(--color-ink)] mb-1" style="font-family: var(--font-sohne);">Standard *</label>
              <select id="grade" name="grade" required class="w-full px-4 py-3 rounded-[var(--radius-inputs)] border border-[var(--color-dove)] bg-[var(--surface-canvas)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-apricot-wash)]" style="font-family: var(--font-sohne);">
                <option value="">Select standard</option>
                {[...Array(12)].map((_, i) => <option value={i + 1}>Std {i + 1}{i >= 11 ? ' (Commerce)' : ''}</option>)}
              </select>
            </div>
            <div>
              <label for="medium" class="block text-sm font-medium text-[var(--color-ink)] mb-1" style="font-family: var(--font-sohne);">Medium *</label>
              <select id="medium" name="medium" required class="w-full px-4 py-3 rounded-[var(--radius-inputs)] border border-[var(--color-dove)] bg-[var(--surface-canvas)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-apricot-wash)]" style="font-family: var(--font-sohne);">
                <option value="">Select medium</option>
                <option value="gujarati">Gujarati Medium</option>
                <option value="english">English Medium</option>
              </select>
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-[var(--color-ink)] mb-1" style="font-family: var(--font-sohne);">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required pattern="[0-9]{10}" title="Enter 10-digit mobile number" class="w-full px-4 py-3 rounded-[var(--radius-inputs)] border border-[var(--color-dove)] bg-[var(--surface-canvas)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-apricot-wash)]" style="font-family: var(--font-sohne);" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-[var(--color-ink)] mb-1" style="font-family: var(--font-sohne);">Message</label>
              <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-[var(--radius-inputs)] border border-[var(--color-dove)] bg-[var(--surface-canvas)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-apricot-wash)] resize-none" style="font-family: var(--font-sohne);"></textarea>
            </div>
            <button type="submit" class="w-full bg-[var(--color-ink)] text-[var(--color-pure-white)] px-6 py-3 rounded-full text-sm font-medium transition-opacity hover:opacity-90" style="font-family: var(--font-sohne);">
              Send Enquiry
            </button>
            <p id="form-status" class="text-sm text-center hidden" style="font-family: var(--font-sohne);"></p>
          </form>
        </div>
      </section>
    </div>

  </div>
</Layout>

<script>
  const form = document.getElementById('enquiry-form');
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', function (e) {
    e.preventDefault();
    const phone = document.getElementById('phone').value.replace(/\D/g, '');
    if (phone.length !== 10) {
      status.textContent = 'Please enter a valid 10-digit phone number.';
      status.className = 'text-sm text-center text-red-500 mt-2';
      status.classList.remove('hidden');
      return;
    }
    status.textContent = 'Thank you! We will contact you soon.';
    status.className = 'text-sm text-center text-green-600 mt-2';
    status.classList.remove('hidden');
    form.reset();
  });
</script>
