---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Eklavya Tuition Classes" description="Get in touch with Eklavya Tuition Classes. Visit us at Sita Rama bazaar or call +91 9949982861.">
  <div class="space-y-16">

    <section>
      <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
        Contact Us
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne); font-size: var(--text-body-lg);">
        Have questions or want to enrol your child? Reach out to us — we're happy to help.
      </p>
    </section>

    <div class="grid md:grid-cols-2 gap-12">
      <section>
        <div class="bg-[var(--surface-fog)] rounded-3xl p-10 space-y-6">
          <div>
            <h3 class="text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider mb-2" style="font-family: var(--font-sohne);">Address</h3>
            <p class="text-[var(--color-graphite)] leading-relaxed" style="font-family: var(--font-sohne); font-size: var(--text-body);">
              Sita Rama bazaar,<br />
              Near Chennupati Petrol Bunk,<br />
              Andhra Pradesh
            </p>
          </div>
          <div>
            <h3 class="text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider mb-2" style="font-family: var(--font-sohne);">Phone</h3>
            <a href="tel:+919949982861" class="text-[var(--color-rust)] hover:underline" style="font-family: var(--font-sohne); font-size: var(--text-body);">
              +91 9949982861
            </a>
          </div>
          <div>
            <h3 class="text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider mb-2" style="font-family: var(--font-sohne);">Email</h3>
            <a href="mailto:eklavya.tuition@gmail.com" class="text-[var(--color-rust)] hover:underline" style="font-family: var(--font-sohne); font-size: var(--text-body);">
              eklavya.tuition@gmail.com
            </a>
          </div>
          <div>
            <h3 class="text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider mb-2" style="font-family: var(--font-sohne);">Timings</h3>
            <p class="text-[var(--color-graphite)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">
              Mon - Sat: 4:00 PM - 8:00 PM<br />
              Sunday: Closed
            </p>
          </div>
        </div>
      </section>

      <section>
        <div class="bg-[var(--surface-card)] rounded-3xl p-10 shadow-[var(--shadow-subtle)] border border-[var(--color-fog)]">
          <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
            Enquiry Form
          </h2>
          <form class="space-y-5" action="#" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium text-[var(--color-ink)] mb-1" style="font-family: var(--font-sohne);">Student Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-[var(--radius-inputs)] border border-[var(--color-dove)] bg-[var(--surface-canvas)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-apricot-wash)]" style="font-family: var(--font-sohne);" />
            </div>
            <div>
              <label for="grade" class="block text-sm font-medium text-[var(--color-ink)] mb-1" style="font-family: var(--font-sohne);">Grade / Class</label>
              <select id="grade" name="grade" required class="w-full px-4 py-3 rounded-[var(--radius-inputs)] border border-[var(--color-dove)] bg-[var(--surface-canvas)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-apricot-wash)]" style="font-family: var(--font-sohne);">
                <option value="">Select class</option>
                {[...Array(10)].map((_, i) => <option value={i + 1}>Class {i + 1}</option>)}
              </select>
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-[var(--color-ink)] mb-1" style="font-family: var(--font-sohne);">Phone Number</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-[var(--radius-inputs)] border border-[var(--color-dove)] bg-[var(--surface-canvas)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-apricot-wash)]" style="font-family: var(--font-sohne);" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-[var(--color-ink)] mb-1" style="font-family: var(--font-sohne);">Message</label>
              <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-[var(--radius-inputs)] border border-[var(--color-dove)] bg-[var(--surface-canvas)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-apricot-wash)] resize-none" style="font-family: var(--font-sohne);"></textarea>
            </div>
            <button type="submit" class="w-full bg-[var(--color-ink)] text-[var(--color-pure-white)] px-6 py-3 rounded-full text-sm font-medium" style="font-family: var(--font-sohne);">
              Send Enquiry
            </button>
          </form>
        </div>
      </section>
    </div>

  </div>
</Layout>
