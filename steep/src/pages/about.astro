---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | Eklavya Tuition Classes" description="Learn about Eklavya Tuition Classes — established 2015 in Surat. Director Yogeshbhai Katariya. Std 1-12 Commerce coaching.">
  <div class="space-y-12 md:space-y-16">

    <section>
      <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
        About Us
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne); font-size: var(--text-body-lg);">
        Established in 2015, Eklavya Tuition Classes (ETC) has been a trusted name in academic coaching for over a decade. Located in Utran, Surat, we provide focused, high-quality education for students from Class 1 to Class 12 (Commerce stream).
      </p>
    </section>

    <section class="grid md:grid-cols-2 gap-12">
      <div class="bg-[var(--section-tint-mint)] rounded-3xl p-10">
        <h2 class="text-[var(--text-heading-sm)] font-serif font-medium mb-4" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
          Our Mission
        </h2>
        <p class="text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">
          To provide every student with a strong academic foundation through personalized coaching, fostering both intellectual growth and character development — in Gujarati and English mediums.
        </p>
      </div>
      <div class="bg-[var(--section-tint-pink)] rounded-3xl p-10">
        <h2 class="text-[var(--text-heading-sm)] font-serif font-medium mb-4" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
          Our Vision
        </h2>
        <p class="text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">
          To be the most trusted tuition center in Surat — known for academic excellence, dedicated faculty, and an environment where every child's future is guaranteed.
        </p>
      </div>
    </section>

    <section>
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Our Story
      </h2>
      <div class="bg-[var(--section-tint-saffron)] rounded-3xl p-10 md:p-12">
        <p class="text-[var(--text-body)] text-[var(--color-ink)] leading-relaxed mb-4" style="font-family: var(--font-sohne); font-size: var(--text-body);">
          Founded by <strong>Yogeshbhai Katariya (M.Com, B.Ed)</strong> with 11 years of experience, Eklavya Tuition Classes began as a small initiative that has grown into a thriving learning community. Over the past 11 years, we have taught over 9,000 students and earned the trust of 18,000+ parents.
        </p>
        <p class="text-[var(--text-body)] text-[var(--color-ink)] leading-relaxed mb-4" style="font-family: var(--font-sohne); font-size: var(--text-body);">
          Located at 310, 3rd Floor, Angel Square, Near Silver Business Point, VIP Circle, Utran, Surat — our centre is equipped with AC classrooms, digital boards, CCTV surveillance, and AI-powered teaching tools.
        </p>
        <p class="text-[var(--text-body)] text-[var(--color-ink)] leading-relaxed" style="font-family: var(--font-sohne); font-size: var(--text-body);">
          We offer coaching in Gujarati and English mediums, from Std 1 through Std 12 Commerce. Our team of 12+ dedicated faculty members covers all subjects with a strategic focus on board exam preparation, weekly tests, and pre-provided booklets with past papers.
        </p>
      </div>
    </section>

    <section class="bg-[var(--section-tint-lavender)] rounded-3xl p-12 text-center">
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-4" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Director
      </h2>
      <div class="w-20 h-20 bg-[var(--color-card-lavender)] rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="text-[var(--color-midnight-ink)] text-2xl font-bold" style="font-family: var(--font-signifier);">YK</span>
      </div>
      <h3 class="text-[var(--text-heading-sm)] font-medium" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
        Yogeshbhai Katariya
      </h3>
      <p class="text-sm text-[var(--color-midnight-ink)] font-medium mt-1" style="font-family: var(--font-sohne);">M.Com, B.Ed — 11 Years Experience</p>
      <p class="text-[var(--color-graphite)] max-w-xl mx-auto mt-4 leading-relaxed" style="font-family: var(--font-sohne); font-size: var(--text-body);">
        "Eklavya — Where trust, education and future are guaranteed!"
      </p>
    </section>

  </div>
</Layout>
