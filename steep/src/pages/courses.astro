---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import HaloHeading from '../components/HaloHeading.astro';

const std10SubjectColors = [
  { bg: 'var(--color-card-saffron)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-lavender)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-mint)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-pink)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-highlight-yellow)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-saffron)', iconColor: 'var(--color-midnight-ink)' },
];

const std12SubjectColors = [
  { bg: 'var(--color-card-pink)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-mint)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-lavender)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-saffron)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-highlight-yellow)', iconColor: 'var(--color-midnight-ink)' },
  { bg: 'var(--color-card-pink)', iconColor: 'var(--color-midnight-ink)' },
];

const std10Subjects = [
  { name: 'English', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'/></svg>", teacher: 'Hardik Sir' },
  { name: 'Social Science', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z'/></svg>", teacher: 'Ankit Sir' },
  { name: 'Science', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'/></svg>", teacher: 'Devendra Sir' },
  { name: 'Maths', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'/></svg>", teacher: 'Sagar Sir' },
  { name: 'Gujarati', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z'/></svg>", teacher: 'Suresh Sir' },
  { name: 'Sanskrit', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 14l9-5-9-5-9 5 9 5z'/><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z'/></svg>", teacher: 'Helvin Sir' },
];

const std12Subjects = [
  { name: 'Accounts', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'/></svg>", teacher: 'Arthik Sir' },
  { name: 'Statistics', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'/></svg>", teacher: 'Yogesh Sir' },
  { name: 'Economics', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M3 21h18M3 10h18M3 7l9-4 9 4M4 10v11m16-11v11M8 14v.5m8-.5v.5M8 18v.5m8-.5v.5'/></svg>", teacher: 'Deepak Sir' },
  { name: 'B.A.', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'/></svg>", teacher: 'Vijay Sir' },
  { name: 'English', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'/></svg>", teacher: 'Hardik Sir' },
  { name: 'Gujarati', icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z'/></svg>", teacher: 'Suresh Sir' },
];

const feeStructure = [
  { standard: '1 to 3', fee: '₹9,000' },
  { standard: '4 & 5', fee: '₹9,500' },
  { standard: '6', fee: '₹10,500' },
  { standard: '7', fee: '₹11,500' },
  { standard: '8', fee: '₹12,500' },
  { standard: '9', fee: '₹14,000' },
  { standard: '10', fee: '₹19,000' },
  { standard: '11', fee: '₹18,000' },
  { standard: '12', fee: '₹19,500' },
];
---

<Layout title="Courses | Eklavya Tuition Classes" description="Std 1 to 12 Commerce coaching in Surat. Gujarati & English medium. Fee structure, subjects, and special courses at Eklavya Tuition Classes." atmosphere="saffron">
  <div class="space-y-12 md:space-y-16">

    <section>
      <Eyebrow text="// COURSES" />
      <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
        Courses
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne); font-size: var(--text-body-lg);">
        Comprehensive academic coaching for Class 1 to Class 12 (Commerce stream) in Gujarati and English mediums at Utran, Surat.
      </p>
    </section>

    <section>
      <Eyebrow text="// MEDIUM" />
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Medium of Instruction
      </h2>
      <div class="flex flex-wrap gap-3">
        <span class="bg-[var(--color-card-saffron)] text-[var(--color-midnight-ink)] px-6 py-3 rounded-full text-base font-medium" style="font-family: var(--font-sohne);">
          Gujarati Medium
        </span>
        <span class="bg-[var(--color-card-saffron)] text-[var(--color-midnight-ink)] px-6 py-3 rounded-full text-base font-medium" style="font-family: var(--font-sohne);">
          English Medium
        </span>
      </div>
    </section>

    <section>
      <Eyebrow text="// STD 10 SUBJECTS" />
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Std 10 Subjects
      </h2>
      <div class="card-grid grid grid-cols-2 lg:grid-cols-3 gap-2 md:gap-6 lg:gap-8">
        {std10Subjects.map((s, i) => (
            <div class="rounded-2xl shadow-[var(--shadow-card)] transition-transform duration-300 hover:scale-[1.02] flex flex-col p-3 md:p-6 lg:p-8" style={`background: color-mix(in srgb, ${std10SubjectColors[i].bg} 10%, white); border-top: 3px solid ${std10SubjectColors[i].bg};`}>
            <div class="w-10 h-10 md:w-12 md:h-12 rounded-full flex items-center justify-center mb-3 md:mb-4 shrink-0 card-icon" style={`background: ${std10SubjectColors[i].bg};`}>
              <span style={`color: ${std10SubjectColors[i].iconColor};`} set:html={s.icon}></span>
            </div>
            <h3 class="text-[13px] md:text-[var(--text-heading-sm)] font-medium mb-1" style="font-family: var(--font-signifier); color: var(--color-ink);">{s.name}</h3>
            <p class="text-xs md:text-sm text-[var(--color-midnight-ink)] grow" style="font-family: var(--font-sohne);">{s.teacher}</p>
          </div>
        ))}
      </div>
    </section>

    <section>
      <Eyebrow text="// STD 12 SUBJECTS" />
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Std 12 Commerce Subjects
      </h2>
      <div class="card-grid grid grid-cols-2 lg:grid-cols-3 gap-2 md:gap-6 lg:gap-8">
        {std12Subjects.map((s, i) => (
          <div class="rounded-2xl shadow-[var(--shadow-card)] transition-transform duration-300 hover:scale-[1.02] flex flex-col p-3 md:p-6 lg:p-8" style={`background: color-mix(in srgb, ${std12SubjectColors[i].bg} 10%, white); border-top: 3px solid ${std12SubjectColors[i].bg};`}>
            <div class="w-10 h-10 md:w-12 md:h-12 rounded-full flex items-center justify-center mb-3 md:mb-4 shrink-0 card-icon" style={`background: ${std12SubjectColors[i].bg};`}>
              <span style={`color: ${std12SubjectColors[i].iconColor};`} set:html={s.icon}></span>
            </div>
            <h3 class="text-[13px] md:text-[var(--text-heading-sm)] font-medium mb-1" style="font-family: var(--font-signifier); color: var(--color-ink);">{s.name}</h3>
            <p class="text-xs md:text-sm text-[var(--color-midnight-ink)] grow" style="font-family: var(--font-sohne);">{s.teacher}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-[var(--section-tint-pink)] rounded-3xl p-12">
      <Eyebrow text="// FEE STRUCTURE" />
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Fee Structure (Annual)
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-[var(--color-dove)]">
              <th class="pb-4 text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider" style="font-family: var(--font-sohne);">Standard</th>
              <th class="pb-4 text-sm font-medium text-[var(--color-ink)] uppercase tracking-wider" style="font-family: var(--font-sohne);">Annual Fee</th>
            </tr>
          </thead>
          <tbody>
            {feeStructure.map(f => (
              <tr class="border-b border-[var(--color-dove)] last:border-0">
                <td class="py-4 text-[var(--color-ink)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">{f.standard}</td>
                <td class="py-4 text-[var(--color-midnight-ink)] font-medium" style="font-family: var(--font-sohne); font-size: var(--text-body);">{f.fee}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <Eyebrow text="// SPECIAL COURSES" />
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Special Courses
      </h2>
      <div class="card-grid grid grid-cols-2 lg:grid-cols-3 gap-2 md:gap-6 lg:gap-8">
        <div class="rounded-2xl shadow-[var(--shadow-card)] transition-transform duration-300 hover:scale-[1.02] flex flex-col p-3 md:p-6 lg:p-8" style="background: color-mix(in srgb, var(--color-card-saffron) 10%, white); border-top: 3px solid var(--color-card-saffron);">
          <p class="text-xs md:text-sm text-[var(--color-graphite)] mb-2" style="font-family: var(--font-sohne);">Std 6 to 10 | ₹800/month</p>
          <p class="text-[11px] md:text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)] grow card-desc" style="font-family: var(--font-sohne);">Strengthen your mathematical foundation with focused coaching and practice.</p>
        </div>
        <div class="rounded-2xl shadow-[var(--shadow-card)] transition-transform duration-300 hover:scale-[1.02] flex flex-col p-3 md:p-6 lg:p-8" style="background: color-mix(in srgb, var(--color-card-mint) 10%, white); border-top: 3px solid var(--color-card-mint);">
          <h3 class="text-[13px] md:text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-signifier); color: var(--color-ink);">Basic English</h3>
          <p class="text-xs md:text-sm text-[var(--color-graphite)] mb-2" style="font-family: var(--font-sohne);">Std 6 to 10 | ₹1,000/month</p>
          <p class="text-[11px] md:text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)] grow card-desc" style="font-family: var(--font-sohne);">Improve your English grammar, vocabulary, and communication skills.</p>
        </div>
        <div class="rounded-2xl shadow-[var(--shadow-card)] transition-transform duration-300 hover:scale-[1.02] flex flex-col p-3 md:p-6 lg:p-8" style="background: color-mix(in srgb, var(--color-card-lavender) 10%, white); border-top: 3px solid var(--color-card-lavender);">
          <h3 class="text-[13px] md:text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-signifier); color: var(--color-ink);">Alphavedic Skill Development</h3>
          <p class="text-xs md:text-sm text-[var(--color-graphite)] mb-2" style="font-family: var(--font-sohne);">Ages 8 to 14</p>
          <p class="text-[11px] md:text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)] grow card-desc" style="font-family: var(--font-sohne);">Abacus & Finger Math program to boost mental arithmetic and cognitive skills.</p>
        </div>
      </div>
    </section>

  </div>
</Layout>
