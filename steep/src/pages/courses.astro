---
import Layout from '../layouts/Layout.astro';

const subjects = [
  {
    name: 'Mathematics',
    icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'/></svg>",
    description: 'From basic arithmetic to advanced algebra — building strong quantitative skills.'
  },
  {
    name: 'Science',
    icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'/></svg>",
    description: 'Physics, Chemistry, and Biology made simple with practical explanations.'
  },
  {
    name: 'Social Studies',
    icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z'/></svg>",
    description: 'History, Geography, Civics, and Economics with real-world connections.'
  },
  {
    name: 'English',
    icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253'/></svg>",
    description: 'Grammar, literature, writing skills, and spoken English development.'
  },
  {
    name: 'Telugu',
    icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z'/></svg>",
    description: 'Telugu language, literature, and grammar for native language proficiency.'
  },
  {
    name: 'Hindi',
    icon: "<svg class='w-6 h-6' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M3 21h18M3 10h18m-9-9l9 4-9 4-9-4 9-4z'/></svg>",
    description: 'Hindi language instruction as second/third language option.'
  },
];

const grades = ['Class 1', 'Class 2', 'Class 3', 'Class 4', 'Class 5', 'Class 6', 'Class 7', 'Class 8', 'Class 9', 'Class 10'];
---

<Layout title="Courses | Eklavya Tuition Classes" description="Explore our courses for Classes 1-10 across all subjects in Telugu and English mediums.">
  <div class="space-y-16">

    <section>
      <h1 class="font-serif font-normal leading-[var(--leading-display)] tracking-[var(--tracking-display)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-display); color: var(--color-ink);">
        Courses
      </h1>
      <p class="text-[var(--text-body-lg)] text-[var(--color-ash)] max-w-3xl leading-[var(--leading-body-lg)]" style="font-family: var(--font-sohne); font-size: var(--text-body-lg);">
        Comprehensive academic coaching for Classes 1 through 10, covering all major subjects in both Telugu and English mediums.
      </p>
    </section>

    <section>
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Grades We Cover
      </h2>
      <div class="flex flex-wrap gap-3">
        {grades.map(g => (
          <span class="bg-[var(--color-apricot-wash)] text-[var(--color-rust)] px-5 py-2 rounded-full text-sm font-medium transition-transform hover:scale-105" style="font-family: var(--font-sohne);">
            {g}
          </span>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-8" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Subjects Offered
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        {subjects.map(s => (
          <div class="bg-[var(--surface-card)] p-8 rounded-2xl shadow-[var(--shadow-subtle)] transition-transform duration-300 hover:scale-[1.02]">
            <div class="w-12 h-12 bg-[var(--color-apricot-wash)] rounded-full flex items-center justify-center mb-4">
              <span class="text-[var(--color-rust)]" set:html={s.icon}></span>
            </div>
            <h3 class="text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
              {s.name}
            </h3>
            <p class="text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">
              {s.description}
            </p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-[var(--surface-warm-tint)] rounded-3xl p-12">
      <h2 class="text-[var(--text-heading)] font-serif font-normal leading-[var(--leading-heading)] tracking-[var(--tracking-heading)] mb-6" style="font-family: var(--font-signifier); font-size: var(--text-heading); color: var(--color-ink);">
        Medium of Instruction
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-[var(--surface-card)] rounded-2xl p-8 shadow-[var(--shadow-subtle)] transition-transform duration-300 hover:scale-[1.02]">
          <h3 class="text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
            Telugu Medium
          </h3>
          <p class="text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">
            Instruction in Telugu for students from Telugu-medium schools. All subjects taught with Telugu as the primary language of explanation.
          </p>
        </div>
        <div class="bg-[var(--surface-card)] rounded-2xl p-8 shadow-[var(--shadow-subtle)] transition-transform duration-300 hover:scale-[1.02]">
          <h3 class="text-[var(--text-heading-sm)] font-medium mb-2" style="font-family: var(--font-signifier); font-size: var(--text-heading-sm); color: var(--color-ink);">
            English Medium
          </h3>
          <p class="text-[var(--text-body)] text-[var(--color-graphite)] leading-[var(--leading-body)]" style="font-family: var(--font-sohne); font-size: var(--text-body);">
            Instruction in English for students from English-medium schools. Focus on strong English communication alongside subject mastery.
          </p>
        </div>
      </div>
    </section>

  </div>
</Layout>
